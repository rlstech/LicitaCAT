#!/usr/bin/env bash
#
# Pre-commit hook — bloqueia commit de segredos.
# Ative uma vez por clone:  git config core.hooksPath .githooks
#
# Usa `gitleaks` se instalado (varredura robusta); caso contrário,
# aplica uma varredura de fallback por padrões conhecidos.

set -euo pipefail

RED=$'\033[0;31m'; YEL=$'\033[0;33m'; NC=$'\033[0m'

fail() {
  echo "${RED}✖ Commit bloqueado: possível segredo detectado.${NC}" >&2
  echo "$1" >&2
  echo "${YEL}Segredos devem ir apenas em *.secrets.env (ignorado) ou Docker secrets — nunca versionados.${NC}" >&2
  echo "Se for um falso positivo, revise ou use 'git commit --no-verify' por sua conta e risco." >&2
  exit 1
}

# 1) Preferir gitleaks quando disponível
if command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged --redact --no-banner; then
    fail "gitleaks encontrou segredos no conteúdo staged."
  fi
  exit 0
fi

# 2) Fallback: varredura por padrões no diff staged (apenas linhas adicionadas)
STAGED_DIFF="$(git diff --cached --unified=0 --no-color -- . ':(exclude)*.example' ':(exclude)pnpm-lock.yaml' || true)"
ADDED="$(printf '%s\n' "$STAGED_DIFF" | grep -E '^\+' | grep -vE '^\+\+\+' || true)"

# Padrões de segredo (chaves reais, não placeholders ${VAR} nem ***REMOVED***)
PATTERNS=(
  'AIza[0-9A-Za-z_\-]{35}'                         # Google API key
  'ghp_[0-9A-Za-z]{36}'                            # GitHub PAT (classic)
  'github_pat_[0-9A-Za-z_]{22,}'                   # GitHub fine-grained PAT
  'sk-[A-Za-z0-9]{20,}'                            # OpenAI/Anthropic style
  're_[0-9A-Za-z]{20,}'                            # Resend
  'AKIA[0-9A-Z]{16}'                               # AWS access key id
  'xox[baprs]-[0-9A-Za-z-]{10,}'                   # Slack
  '-----BEGIN [A-Z ]*PRIVATE KEY-----'             # PEM private key
  'licitacat-secret-change-in-prod-2026'           # segredo fraco conhecido deste repo
)

HITS=""
for p in "${PATTERNS[@]}"; do
  m="$(printf '%s\n' "$ADDED" | grep -nEo -e "$p" | grep -v 'REMOVED' || true)"
  [ -n "$m" ] && HITS="${HITS}\n  padrão '${p}':\n$(printf '%s' "$m" | sed 's/^/    /')"
done

if [ -n "$HITS" ]; then
  fail "$(printf '%b' "$HITS")"
fi

exit 0
