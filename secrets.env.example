# Copie este arquivo para /root/licitacat.secrets.env no servidor
# e preencha os valores reais. NUNCA commite o arquivo com valores reais.
#
# Para gerar um BETTER_AUTH_SECRET seguro:
#   openssl rand -base64 32

# ── Autenticação ───────────────────────────────────────────────
BETTER_AUTH_SECRET=

# ── Banco de dados ─────────────────────────────────────────────
POSTGRES_USER=licitacat
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/licitacat

# ── MinIO / S3 ─────────────────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
# Para dev sem domínio verificado: onboarding@resend.dev
# Para produção: noreply@licitacat.railton.eu.org (requer DNS verificado no Resend)
RESEND_FROM_EMAIL=onboarding@resend.dev

# ── IA (Google) ────────────────────────────────────────────────
GEMINI_API_KEY=
